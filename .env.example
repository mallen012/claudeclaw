# ClaudeClaw v2 — environment configuration
# Copy to .env and fill in your values. The setup wizard will walk you through this.

# ═══════════════════════════════════════════════════════════════════
# REQUIRED — Telegram
# ═══════════════════════════════════════════════════════════════════

# Get from @BotFather in Telegram. This is the MAIN agent's bot.
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (the bot will print it on first message, or use @userinfobot).
ALLOWED_CHAT_ID=

# ═══════════════════════════════════════════════════════════════════
# Claude Code / Agent SDK
# ═══════════════════════════════════════════════════════════════════

# Default model for all agents (individual agents can override via agent.yaml).
AGENT_MODEL=claude-sonnet-4-6

# Max tool-use turns per message (safety cap against runaway loops).
AGENT_MAX_TURNS=30

# Agent timeout in milliseconds (15 minutes default).
AGENT_TIMEOUT_MS=900000

# Cost footer mode: compact | verbose | cost | full | off
SHOW_COST_FOOTER=compact

# Streaming strategy: global-throttle | single-agent-only | off
STREAM_STRATEGY=off

# External config directory (agent.yaml, overrides). Defaults to ~/.claudeclaw.
CLAUDECLAW_CONFIG=

# ═══════════════════════════════════════════════════════════════════
# Memory v2 (Gemini)
# ═══════════════════════════════════════════════════════════════════

# Google AI Studio key — free tier. Covers Memory v2, video analysis, War Room (Gemini Live).
# https://aistudio.google.com/
GOOGLE_API_KEY=

# Nudge proactive memory surface every N turns.
MEMORY_NUDGE_INTERVAL_TURNS=10

# Nudge proactive memory surface every N hours.
MEMORY_NUDGE_INTERVAL_HOURS=2

# ═══════════════════════════════════════════════════════════════════
# Voice — Groq STT
# ═══════════════════════════════════════════════════════════════════

# Groq Whisper API key — free tier, generous limits.
# https://console.groq.com/keys
GROQ_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# Security
# ═══════════════════════════════════════════════════════════════════

# PIN lock — salted SHA-256 hash as salt:hash (the setup wizard generates this).
CLAUDECLAW_PIN_HASH=

# Idle auto-lock after N minutes with no activity.
IDLE_LOCK_MINUTES=30

# Kill phrase — case-insensitive exact match triggers emergency shutdown.
KILL_PHRASE=

# ═══════════════════════════════════════════════════════════════════
# Dashboard
# ═══════════════════════════════════════════════════════════════════

# Bearer-style token appended as ?token= when opening the dashboard. Leave blank to disable auth.
DASHBOARD_TOKEN=

# ═══════════════════════════════════════════════════════════════════
# War Room
# ═══════════════════════════════════════════════════════════════════

# Mode: live (Gemini Live, default) | legacy (Deepgram + Cartesia)
WARROOM_MODE=live

# Only needed if WARROOM_MODE=legacy.
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# Meeting bot (Recall.ai)
# ═══════════════════════════════════════════════════════════════════

# Recall.ai key — voice-only meeting bot, supports Google Meet, Zoom, Webex, Teams.
# https://www.recall.ai/
RECALL_API_KEY=

# ═══════════════════════════════════════════════════════════════════
# Scheduler / Mission Control
# ═══════════════════════════════════════════════════════════════════

# Default target chat ID for scheduled tasks (falls back to ALLOWED_CHAT_ID).
SCHEDULER_DEFAULT_CHAT_ID=

# ═══════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════

LOG_LEVEL=info
NODE_ENV=production
